{"collection":{"info":{"_postman_id":"53808324-5ce6-4c9f-9ee4-ae4cbd9c24c9","name":"Team_Collection","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json","createdAt":"2026-03-25T09:25:51.000Z","updatedAt":"2026-03-26T07:22:43.000Z","lastUpdatedBy":"53509205","uid":"53482408-53808324-5ce6-4c9f-9ee4-ae4cbd9c24c9"},"item":[{"name":"Auth","item":[{"name":"Login","event":[{"listen":"test","script":{"id":"d551bd77-5ac5-4f9c-8957-0563602f2a92","exec":["var jsonData = pm.response.json();\r","\r","pm.test(\"Status code is 200\", () => {\r","    pm.response.to.have.status(200);\r","});\r","\r","pm.test(\"User id correct\", () => {\r","    pm.expect(jsonData.id).to.eql(1);\r","});\r","pm.collectionVariables.set(\"access_token\", jsonData.accessToken);\r","pm.collectionVariables.set(\"refresh_token\", jsonData.refreshToken);"],"type":"text/javascript","packages":{},"requests":{}}},{"listen":"prerequest","script":{"id":"4c8b7d1f-db58-4fb0-9977-efd04e7c15dd","exec":["// pm.environment.set(\"userID\", \"{{user_ID}}\");"],"type":"text/javascript","packages":{},"requests":{}}}],"id":"bc6c93f4-a686-4fd9-8c4c-58ec53928862","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"POST","header":[],"body":{"mode":"raw","raw":"{\r\n    \"username\": \"emilys\",\r\n    \"password\": \"emilyspass\",\r\n    \"expiresInMins\": 30\r\n}","options":{"raw":{"language":"json"}}},"url":{"raw":"{{baseUrl}}/login","host":["{{baseUrl}}"],"path":["login"]}},"response":[],"createdAt":"2026-03-25T10:06:09.000Z","updatedAt":"2026-03-26T06:57:44.000Z","uid":"53482408-bc6c93f4-a686-4fd9-8c4c-58ec53928862"},{"name":"Create user","event":[{"listen":"test","script":{"id":"a758d003-bd2b-4823-9184-b2531f7a43f8","exec":["// 1. Check status code is 201 Created\r","pm.test(\"Status code is 201\", function () {\r","    pm.response.to.have.status(201);\r","});\r","\r","// 2. Check response time is under 3000ms\r","pm.test(\"Response time is acceptable\", function () {\r",