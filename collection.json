                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"firstName\": \"Anifa\",\r\n  \"lastName\": \"User\",\r\n  \"email\": \"user_{{$timestamp}}@test.com\",\r\n  \"username\": \"Anifauser_{{$timestamp}}\",\r\n  \"password\": \"test123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
