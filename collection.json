              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Response time\r",
                  "pm.test(\"Response time is acceptable\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "// 3. Verify the updated value is reflected in response\r",
                  "pm.test(\"firstName was updated correctly\", function () {\r",
                  "    pm.expect(jsonData.firstName).to.eql(pm.iterationData.get(\"updateFirstName\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User ID is correct\", function () {\r",
                  "    pm.expect(jsonData.id).to.eql(pm.iterationData.get(\"userId\"));\r",
                  "});\r",
                  "\r",
                  "const savedUserId = pm.iterationData.get(\"userId\");\r",
                  "pm.test(\"userId is available from environment\", function () {\r",
                  "    pm.expect(savedUserId).to.not.be.undefined;\r",
                  "});\r",
                  ""
