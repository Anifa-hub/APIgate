      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.environment.set(\"access_token\", jsonData.accessToken);\r",
                  "\r",
                  "pm.test(\"User id correct\", () => {\r",
                  "    pm.expect(jsonData.id).to.eql(pm.iterationData.get(\"userId\"));\r",
                  "});\r",
                  "pm.collectionVariables.set(\"access_token\", jsonData.accessToken);\r",
                  "pm.collectionVariables.set(\"refresh_token\", jsonData.refreshToken);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// pm.environment.set(\"userID\", \"{{user_ID}}\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"{{loginUsername}}\",\r\n    \"password\": \"{{loginPassword}}\",\r\n    \"expiresInMins\": 70\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Check status code is 201 Created\r",
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "// 2. Check response time is under 3000ms\r",
                  "pm.test(\"Response time is acceptable\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
                  "});\r",
                  "\r",
                  "// 3. Parse the response body as JSON\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "// 4. Check the response has an 'id' field\r",
                  "pm.test(\"Response has an id\", function () {\r",
                  "    pm.expect(jsonData).to.have.property('id');\r",
                  "});\r",
                  "\r",
                  "// 5. Check firstName matches what we sent\r",
                  "pm.test(\"firstName is correct\", function () {\r",
                  "    pm.expect(jsonData.firstName).to.eql(\"Anifa\");\r",
                  "});\r",
                  "\r",
                  "// 6. Save the returned userId to environment (for reference)\r",
                  "pm.environment.set(\"userId\", jsonData.id);\r",
                  "pm.test(\"userId saved to environment\", function () {\r",
                  "    pm.expect(pm.environment.get(\"userId\")).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
