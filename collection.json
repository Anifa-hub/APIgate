    {
      "name": "User management",
      "item": [
        {
          "name": "Fetch a single user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Status code\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Response time\r",
                  "pm.test(\"Response time is acceptable\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "// 3. Check key fields exist\r",
                  "pm.test(\"Response has required fields\", function () {\r",
                  "    pm.expect(jsonData).to.have.property('id');\r",
                  "    pm.expect(jsonData).to.have.property('firstName');\r",
                  "    pm.expect(jsonData).to.have.property('lastName');\r",
                  "    pm.expect(jsonData).to.have.property('email');\r",
                  "    pm.expect(jsonData).to.have.property('age');\r",
                  "});\r",
                  "\r",
                  "// 4. Schema Validation — enforce data types strictly\r",
                  "pm.test(\"Schema validation - data types are correct\", function () {\r",
                  "    pm.expect(jsonData.id).to.be.a('number');\r",
                  "    pm.expect(jsonData.firstName).to.be.a('string');\r",
                  "    pm.expect(jsonData.lastName).to.be.a('string');\r",
                  "    pm.expect(jsonData.email).to.be.a('string');\r",
                  "    pm.expect(jsonData.age).to.be.a('number');\r",
                  "    pm.expect(jsonData.phone).to.be.a('string');\r",
                  "\r",
                  "    pm.expect(jsonData.hair).to.be.an('object');\r",
                  "});\r",
                  "\r",
                  "// 5. Verify user ID is correct\r",
                  "pm.test(\"User ID is correct\", () => {\r",
                  "    var userid = pm.iterationData.get(\"userId\");\r",
                  "    pm.expect(jsonData.id).to.eql(Number(userid));\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set(\"user_ID\", pm.iterationData.get(\"user_ID\"))"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
